###########################################################################
# modules/root.zsh
#
# Detección de usuario root.
###########################################################################

typeset -g __ZSH_IS_ROOT=0

###########################################################################
# root::update()
###########################################################################

root::update() {

    if [[ "$EUID" -eq 0 ]]; then
        __ZSH_IS_ROOT=1
    else
        __ZSH_IS_ROOT=0
    fi
}

###########################################################################
# root::symbol()
###########################################################################

root::symbol() {

    if [[ $__ZSH_IS_ROOT -eq 1 ]]; then
        printf "%s root" "$I_ROOT"
    else
        printf "%s" "$USER"
    fi
}

###########################################################################
# Init
###########################################################################

root::update