###########################################################################
# modules/ssh.zsh
#
# Detección de sesión SSH.
###########################################################################

typeset -g __ZSH_IN_SSH=0

###########################################################################
# ssh::update()
#
# Detecta si la sesión es remota.
###########################################################################

ssh::update() {

    # SSH_CONNECTION o SSH_CLIENT existen solo en sesiones remotas
    if [[ -n "$SSH_CONNECTION" || -n "$SSH_CLIENT" ]]; then
        __ZSH_IN_SSH=1
    else
        __ZSH_IN_SSH=0
    fi
}

###########################################################################
# ssh::symbol()
###########################################################################

ssh::symbol() {

    [[ $__ZSH_IN_SSH -eq 1 ]] || return

    printf "%s SSH" "$I_SSH"

}

###########################################################################
# Hook (solo al iniciar shell, no cambia durante sesión)
###########################################################################

ssh::update