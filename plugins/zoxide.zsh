###########################################################################
# plugins/zoxide.zsh
#
# Integración de zoxide con ZSH.
#
# Permite navegación inteligente basada en uso:
#
#   z proyecto
#   z homelab
#
# Sustituye cd en muchos casos.
###########################################################################

###########################################################################
# Comprobación
###########################################################################

if ! command -v zoxide >/dev/null 2>&1; then
    return
fi

###########################################################################
# Inicialización
###########################################################################

# Inicializa zoxide en modo ZSH.
eval "$(zoxide init zsh)"

###########################################################################
# Alias principal
###########################################################################

# Sustituye cd inteligente
alias cd="z"

###########################################################################
# Funciones auxiliares
###########################################################################

###########################################################################
# zd()
#
# Variante explícita de cd tradicional si se necesita evitar zoxide.
###########################################################################

zd() {
    builtin cd "$@"
}

###########################################################################
# zf()
#
# Navegación fuzzy dentro de directorios frecuentes.
###########################################################################

zf() {

    local dir

    dir=$(zoxide query -l | fzf \
        --prompt="Zoxide > " \
        --preview="eza --tree --level=2 {} 2>/dev/null")

    [[ -n "$dir" ]] && cd "$dir"
}

###########################################################################
# Fin
###########################################################################